# Copy this file to ".env" in the project root.
# Expo automatically loads EXPO_PUBLIC_* variables and inlines them at bundle
# time, so RESTART the dev server after changing them: `npm run start:clear`.

# Realtime server (Render). Guest play works with just this — src/config.ts
# already defaults to the deployed server, so you usually don't need to set it.
EXPO_PUBLIC_SOCKET_URL=https://code-names-h3ar.onrender.com

# Web app (Vercel). REQUIRED for accounts, friends, and invites — the mobile app
# logs in against its /api/auth endpoints. Also used to load Codenames: Pictures
# card images. Set this to your deployed Vercel domain (no trailing slash).
EXPO_PUBLIC_WEB_URL=https://your-app.vercel.app

{
  "expo": {
    "name": "Codenames",
    "slug": "codenames-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "codenames",
    "assetBundlePatterns": ["**/*"],
    "splash": {
